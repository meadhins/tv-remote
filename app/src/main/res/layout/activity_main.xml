<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#1a1a1a">

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Initializing..."
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/powerBtn"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:text="POWER"
        android:textSize="22sp"
        android:backgroundTint="#cc0000"
        android:textColor="#ffffff"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/prevBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◀ PREV"
            android:backgroundTint="#555555"
            android:textColor="#ffffff"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/foundBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ WORKED!"
            android:backgroundTint="#007700"
            android:textColor="#ffffff"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/jumpInput"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:hint="Jump to #"
            android:textColor="#ffffff"
            android:textColorHint="#888888"
            android:inputType="number"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/jumpBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GO"
            android:backgroundTint="#0055cc"
            android:textColor="#ffffff"/>

    </LinearLayout>

    <TextView
        android:id="@+id/codeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#aaffaa"
        android:textSize="13sp"
        android:gravity="center"/>

</LinearLayout>
