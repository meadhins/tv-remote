<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05050a"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Header Panel Readout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginTop="12dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Living Room"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LG OLED • 38KHZ"
            android:textColor="#7af5c8"
            android:textSize="11sp"
            android:letterSpacing="0.05"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Central Interactive Radial Directional Controller -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center">

        <!-- Replaced background drawable with plain background color directly -->
        <RelativeLayout
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:background="#111126">

            <Button
                android:id="@+id/btnUp"
                android:layout_width="60dp"
                android:layout_height="40dp"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:text="▲"
                android:textColor="#6d6d80"
                android:textSize="16sp"
                android:background="?android:attr/selectableItemBackgroundBorderless" />

            <Button
                android:id="@+id/btnLeft"
                android:layout_width="40dp"
                android:layout_height="60dp"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:layout_marginLeft="16dp"
                android:text="◀"
                android:textColor="#6d6d80"
                android:textSize="16sp"
                android:background="?android:attr/selectableItemBackgroundBorderless" />

            <Button
                android:id="@+id/btnOk"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_centerInParent="true"
                android:text="OK"
                android:textColor="#ffffff"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:background="#181830" />

            <Button
                android:id="@+id/btnRight"
                android:layout_width="40dp"
                android:layout_height="60dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_marginRight="16dp"
                android:text="▶"
                android:textColor="#6d6d80"
                android:textSize="16sp"
                android:background="?android:attr/selectableItemBackgroundBorderless" />

            <Button
                android:id="@+id/btnDown"
                android:layout_width="60dp"
                android:layout_height="40dp"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="16dp"
                android:text="▼"
                android:textColor="#6d6d80"
                android:textSize="16sp"
                android:background="?android:attr/selectableItemBackgroundBorderless" />
        </RelativeLayout>
    </RelativeLayout>

    <!-- Adjustment Zone Deck -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- System Action Strip Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <Button
                android:id="@+id/btnPower"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginRight="6dp"
                android:text="Power"
                android:textColor="#ffffff"
                android:backgroundTint="#111126" />
            <Button
                android:id="@+id/btnInput"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginLeft="6dp"
                android:text="Input"
                android:textColor="#ffffff"
                android:backgroundTint="#111126" />
        </LinearLayout>

        <!-- Ergonomic Volume Slider Pill -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#111126"
            android:layout_marginBottom="12dp"
            android:paddingHorizontal="16dp">
            <Button
                android:id="@+id/btnVolDown"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:text="−"
                android:textColor="#ffffff"
                android:textSize="18sp"
                android:background="?android:attr/selectableItemBackgroundBorderless" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="horizontal"
                android:gravity="center">
                <TextView
                    android:id="@+id/txtVolNum"
                    android:layout_width="30dp"
                    android:layout_height="wrap_content"
                    android:text="28"
                    android:textColor="#ffffff"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VOLUME"
                    android:textColor="#6d6d80"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginLeft="8dp" />
            </LinearLayout>
            <Button
                android:id="@+id/btnVolUp"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:text="+"
                android:textColor="#ffffff"
                android:textSize="18sp"
                android:background="?android:attr/selectableItemBackgroundBorderless" />
        </RelativeLayout>

        <!-- Ergonomic Channel Slider Pill -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#111126"
            android:layout_marginBottom="24dp"
            android:paddingHorizontal="16dp">
            <Button
                android:id="@+id/btnChDown"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:text="▼"
                android:textColor="#ffffff"
                android:textSize="12sp"
                android:background="?android:attr/selectableItemBackgroundBorderless" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="horizontal"
                android:gravity="center">
                <TextView
                    android:id="@+id/txtChNum"
                    android:layout_width="30dp"
                    android:layout_height="wrap_content"
                    android:text="125"
                    android:textColor="#ffffff"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHANNEL"
                    android:textColor="#6d6d80"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginLeft="8dp" />
            </LinearLayout>
            <Button
                android:id="@+id/btnChUp"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:text="▲"
                android:textColor="#ffffff"
                android:textSize="12sp"
                android:background="?android:attr/selectableItemBackgroundBorderless" />
        </RelativeLayout>
    </LinearLayout>

    <!-- Structural Navigation System Footprint Base Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#15152c"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"/>

    <!-- Bottom Deck Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@android:color/transparent">
        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back"
            android:textColor="#52526b"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:layout_marginRight="16dp" />
        <Button
            android:id="@+id/btnHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textColor="#52526b"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:layout_marginRight="16dp" />
        <Button
            android:id="@+id/btnMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Menu"
            android:textColor="#52526b"
            android:background="?android:attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <Button android:id="@+id/btnMute" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
</LinearLayout>
